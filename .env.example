# ================================================
# Smart Inventory Management System - Frontend
# Environment Variables Template
# ================================================

# API Configuration
# -----------------
# Backend API Base URL
# Development: http://localhost:8000
# Production: https://eap-assessment-backend.onrender.com

VITE_API_URL=http://localhost:8000


# Optional Configuration
# ----------------------

# App Environment (development, staging, production)
# VITE_APP_ENV=development

# Enable/Disable Debug Mode
# VITE_DEBUG=false

# API Request Timeout (milliseconds)
# VITE_API_TIMEOUT=30000

# Token Refresh Interval (milliseconds)
# VITE_TOKEN_REFRESH_INTERVAL=240000


# ================================================
# Instructions:
# ================================================
# 1. Copy this file to .env or .env.local
# 2. Update VITE_API_URL with your backend URL
# 3. Never commit .env files with real values to git
# 4. All variables must start with VITE_ to be accessible in the app
#
# For local development:
#   VITE_API_URL=http://localhost:8000
#
# For production (Vercel):
#   VITE_API_URL=https://eap-assessment-backend.onrender.com
#
# ================================================
